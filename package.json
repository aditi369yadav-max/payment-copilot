{
  "name": "payment-copilot",
  "version": "1.0.0",
  "description": "LLM-Powered Payment Operations Copilot — AI agent that debugs payment failures",
  "scripts": {
    "dev":         "ts-node-dev --respawn src/api/server.ts",
    "build":       "tsc",
    "start":       "node dist/api/server.js",
    "seed":        "ts-node src/utils/seedData.ts",
    "postinstall": "npm run build && npm run seed"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
